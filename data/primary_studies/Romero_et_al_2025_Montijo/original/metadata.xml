            <nominal>
              <nonNumericDomain>
                <enumeratedDomain>
                  <codeDefinition>
                    <code>not specified</code>
                    <definition>No additional details regarding bulk density methodology were provided</definition>
                  </codeDefinition>
                  <codeDefinition>
                    <code>to constant mass</code>
                    <definition>Bulk density methodology did not specify drying temperature or length, only that samples were dried to a constant mass</definition>
